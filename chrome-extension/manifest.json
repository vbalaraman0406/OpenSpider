{
    "manifest_version": 3,
    "name": "OpenSpider Browser Relay",
    "version": "1.1.0",
    "description": "Relays Chrome Developer Protocol (CDP) commands from the OpenSpider agent to the active tab.",
    "permissions": [
        "debugger",
        "tabs",
        "activeTab",
        "storage",
        "cookies"
    ],
    "host_permissions": [
        "http://127.0.0.1:*/*",
        "http://localhost:*/*",
        "*://*/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://* https://* ws://* wss://*"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}
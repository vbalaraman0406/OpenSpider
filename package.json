{
  "name": "openspider",
  "version": "1.0.0",
  "description": "Autonomous Multi-Agent System tailored for WhatsApp",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev:backend": "nodemon src/index.ts",
    "dev:frontend": "cd dashboard && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd dashboard && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@google/genai": "latest",
    "@whiskeysockets/baileys": "^6.7.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ollama": "^0.5.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
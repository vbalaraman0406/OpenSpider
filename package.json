{
  "name": "openspider",
  "version": "2.3.1",
  "description": "Autonomous Multi-Agent System tailored for WhatsApp",
  "main": "src/index.ts",
  "bin": {
    "openspider": "./dist/cli.js"
  },
  "scripts": {
    "postinstall": "(cd dashboard && npm install --no-fund --no-audit) && node scripts/patch-baileys.js",
    "start": "ts-node src/index.ts",
    "dev:backend": "nodemon src/index.ts",
    "dev:frontend": "cd dashboard && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "tsc && chmod +x dist/cli.js",
    "build:frontend": "cd dashboard && npm run build",
    "build": "npm run build:backend && npm run build:frontend"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^0.9.0",
    "@google/genai": "latest",
    "@types/better-sqlite3": "^7.6.13",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "gemini-ai": "^2.2.1",
    "ghost-cursor-playwright": "^2.1.0",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonrepair": "^3.13.2",
    "keytar": "^7.9.0",
    "node-cache": "^5.1.2",
    "ollama": "^0.5.12",
    "open": "^11.0.0",
    "playwright-core": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "pm2": "^6.0.14",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
